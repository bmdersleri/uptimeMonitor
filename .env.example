APP_NAME=Ekont Uptime Monitor
APP_URL=https://www.kirbas.com/uptime
APP_BASE_PATH=/uptime
APP_TIMEZONE=Europe/Istanbul
APP_DEBUG=true
HTTP_SSL_VERIFY=true

# Ilk admin olusturma icin (database/create_admin.php)
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
# Web tabanli ilk admin kurulumu (onerilir)
FIRST_ADMIN_SETUP_ENABLED=true
# Guvenlik icin rastgele bir deger verin. Ornek URL:
# /setup_admin.php?token=BURADAKI_DEGER
FIRST_ADMIN_SETUP_TOKEN=

DB_DRIVER=sqlite
DB_PATH=database/database.sqlite
# Production absolute path (server):
# DB_PATH=/home2/cylcoinc/kirbas.com/uptime/database/database.sqlite

# MySQL kullanacaksaniz:
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=ekont_uptime
# DB_USER=root
# DB_PASS=
# DB_CHARSET=utf8mb4

DEFAULT_UPTIME_INTERVAL_SECONDS=300
DEFAULT_TIMEOUT_SECONDS=10
DEFAULT_FAIL_THRESHOLD=3
DEFAULT_RECOVERY_THRESHOLD=2
DEFAULT_RESPONSE_WARNING_MS=3000
DEFAULT_LINK_SCAN_INTERVAL_SECONDS=21600
DEFAULT_LINK_SCAN_MAX_DEPTH=3
DEFAULT_LINK_SCAN_MAX_URLS=120
DEFAULT_LINK_SCAN_CONCURRENCY=5
DEFAULT_LINK_SCAN_REQUEST_TIMEOUT_SECONDS=6
DEFAULT_LINK_SCAN_STALE_AFTER_MINUTES=60
LINK_SCAN_BATCH_SIZE=5

# Bildirim ayarlari
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_TO=
NOTIFY_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
NOTIFY_RETRY_BATCH_SIZE=30
