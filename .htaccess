Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
RewriteEngine On

# Keep direct access to known public entry files.
RewriteRule ^(index|login|logout|setup_admin|monitors_create|monitor_edit|monitor_detail|broken_links|link_scans|retry_queue|link_scan_run|link_scan_status)\.php$ - [L]

# Route pretty root /uptime/ to index.php
RewriteRule ^$ index.php [L]
</IfModule>

# Block direct web access to sensitive/internal directories
RedirectMatch 403 ^/app/
RedirectMatch 403 ^/config/
RedirectMatch 403 ^/cron/
RedirectMatch 403 ^/database/
RedirectMatch 403 ^/storage/

<FilesMatch "^(\.env|bootstrap\.php)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
